# IDE / agent
.codex/
.harness/
.mavis/
.opencode/
.claude/

# patch 工具的备份文件（patch / git apply 失败时自动生成）
*.orig

# === Go / Wails 构建产物 ===
build/
!build/
build/*
!build/appicon.png
!build/appicon.svg
build/bin/
build/windows/
build/darwin/
build/linux/
*.exe
*.dll
*.so
*.dylib
*.app
# === Wails 前端构建产物（v2：dist/ 不入仓；wailsjs/ 是 Wails 生成的 binding，需要入仓）===
frontend/dist/

# Wails build 产物的 md5 校验文件（pnpm 生成，运行时重建）
frontend/package.json.md5
frontend/dist/package.json.md5

# Go 测试覆盖率
*.out

# 临时/缓存
*.log
.DS_Store
.tmp/
.cache/

# 时间轴视觉调参过程截图（M6 调参草稿，不入仓）
notes/cap_*.png

# 调研用第三方 API 文档（gitea swagger yaml，不入仓）
docs/plugin-redoc-2.yaml

# giteaDemo —— 本地 Gitea 测试服务目录（不入仓）
giteaDemo/
.codegraph
.reasonix
reasonix.toml
node_modules/
.playwright-mcp/
# .github/ 大多是 cache，跑 CI 时让 workflows 仍然生效
# 端未跟踪 .github/* 文件，但 .github/workflows/ 必须走 git 控制
.github/*
!/.github/workflows/
!/.github/CODEOWNERS
# .tools/ 是 v3.0 早期 vscode-git-graph 对比工具（已被 tools/vscode-recheck/ 取代）。
# 当前无物理目录、无 git 引用、无代码引用；保留规则防止未来误引入。
.tools/

# Local build artifacts (防止 wails build / go build 产物误提交)
# `/debug` 是仓库根的 Go 二进制，`/tools/*/debug` 是 tools/ 下各子命令的 Go build 产物
# （例如 tools/vscode-recheck/debug 是独立的 HTML 调试工具，不能 commit 它的 build 产物）
/debug
/tools/*/debug
.qoder
.reasonix-commit-msg.txt
.worktrees/
.cu-screenshots/