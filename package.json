{
  "name": "gitea-kanban",
  "version": "0.1.0",
  "description": "基于 gitea 的桌面端看板 + 时间轴工具（强 git 集成 / 零术语 / PAT + keychain）",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "type-check": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.json --noEmit",
    "type-check:main": "tsc -p tsconfig.node.json --noEmit",
    "type-check:renderer": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\"",
    "db:seed": "tsx scripts/seed-kanban-demo.ts",
    "check:no-jargon": "tsx scripts/check-no-jargon.ts",
    "e2e:w3": "node scripts/_e2e-runner.mjs scripts/e2e-verify-w3.ts"
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.3.0",
    "dompurify": "^3.4.10",
    "electron-store": "^11.0.2",
    "gitea-js": "^1.23.0",
    "markdown-it": "^14.2.0",
    "pino": "^9.5.0",
    "vue-draggable-plus": "^0.6.1",
    "vue-router": "^4.6.4",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@napi-rs/keyring-darwin-arm64": "^1.3.0",
    "@napi-rs/keyring-darwin-x64": "^1.3.0",
    "@napi-rs/keyring-linux-arm64-gnu": "^1.3.0",
    "@napi-rs/keyring-linux-arm64-musl": "^1.3.0",
    "@napi-rs/keyring-linux-x64-gnu": "^1.3.0",
    "@napi-rs/keyring-linux-x64-musl": "^1.3.0",
    "@napi-rs/keyring-win32-x64-msvc": "^1.3.0"
  },
  "devDependencies": {
    "@antv/x6": "^3.1.7",
    "@antv/x6-vue-shape": "^3.0.2",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@testing-library/vue": "^8.1.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.11",
    "electron": "^41.7.2",
    "electron-builder": "^26.15.2",
    "electron-vite": "^5.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.32.0",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.4.2",
    "tslib": "^2.8.1",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vite": "^7.3.5",
    "vitest": "^4.1.8",
    "vue": "^3.5.35"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@electron-toolkit/utils"
      ]
    }
  }
}
